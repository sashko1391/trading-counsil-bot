# ===== AI APIs (required — 4 council agents) =====
ANTHROPIC_API_KEY=sk-ant-api03-get-from-console.anthropic.com
XAI_API_KEY=xai-get-from-console.x.ai
GOOGLE_AI_API_KEY=get-from-aistudio.google.com
PERPLEXITY_API_KEY=pplx-get-from-perplexity.ai

# ===== OpenAI (embeddings for RAG + summary) =====
OPENAI_API_KEY=sk-proj-get-from-platform.openai.com

# ===== RAG / Pinecone =====
PINECONE_API_KEY=pcsk_get-from-pinecone.io
PINECONE_INDEX=oil-intelligence
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ===== AI Models =====
GROK_MODEL=grok-3-latest
CLAUDE_SONNET_MODEL=claude-sonnet-4-6
CLAUDE_OPUS_MODEL=claude-opus-4-6
GEMINI_MODEL=gemini-2.5-pro
GEMINI_ADVERSARIAL_MODEL=gemini-2.5-pro
OPENAI_SUMMARY_MODEL=gpt-4o
PERPLEXITY_MODEL=sonar

# ===== Data Providers =====
DATA_PROVIDER=yfinance
EIA_API_KEY=get-from-eia.gov
# Optional paid providers:
# OILPRICEAPI_KEY=get-from-oilpriceapi.com
# DATABENTO_API_KEY=get-from-databento.com
# NASDAQ_DATA_LINK_KEY=get-from-data.nasdaq.com

# ===== Telegram (notifications) =====
TELEGRAM_BOT_TOKEN=get-from-botfather
TELEGRAM_CHAT_ID=your_chat_id

# ===== Adversarial Stage =====
ADVERSARIAL_ENABLED=true

# ===== Paths =====
JOURNAL_PATH=data/trades.json
KNOWLEDGE_PATH=data/knowledge
LOG_LEVEL=INFO
